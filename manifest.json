{
  "manifest_version": 3,
  "name": "Sellers.json Inspector",
  "version": "1.2.0",
  "description": "Parsing, highlighting, and analysis of sellers.json and buyers.json files with IAB-spec ads.txt validation.",
  "permissions": ["storage"],
  "host_permissions": ["*://*/*"],
  "icons": {
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/sellers.json",
        "*://*/sellers.json?*",
        "*://*/*sellers.json",
        "*://*/*sellers.json?*",
        "*://*/buyers.json",
        "*://*/buyers.json?*",
        "*://*/*buyers.json",
        "*://*/*buyers.json?*"
      ],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  }
}
